##
  Description: Runs the map fixture for array transformation behavior.
##
entry main = f(args: string[]): void =>
    let xs: int32[] = [1 as int32, 2 as int32, 3 as int32]
    let doubled = xs.map(f(x: int32): int32 => x * (2 as int32))
    print('length {doubled.length}')
    print('values {doubled[0]} {doubled[1]} {doubled[2]}')
    return void
