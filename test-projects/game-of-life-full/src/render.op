import stdout_writer, writer_write_sync, writer_flush_sync, stdout_terminal, terminal_supports_ansi, terminal_clear_screen_on_sync, int64_to_string from standard
import is_alive_at from ./board

##
  Description: Clears the terminal once when ANSI cursor control is available for animation.
##
public let prepare_display = f(): void errors TerminalWriteFailureError, SinkClosedError =>
    let terminal = stdout_terminal()
    if terminal_supports_ansi(terminal):
        propagate terminal_clear_screen_on_sync(terminal)
    return void

##
  Description: Clears supported terminals, streams one complete frame, and flushes after the final row.
##
public let write_frame = f(width: int64, height: int64, board: int8[], generation: int64): void errors WriteFailureError, FlushFailureError, SinkClosedError, TerminalWriteFailureError =>
    let terminal = stdout_terminal()
    let writer = stdout_writer()
    if terminal_supports_ansi(terminal):
        propagate terminal_clear_screen_on_sync(terminal)
    else:
        propagate writer_write_sync(writer, '\n')

    let generation_text = int64_to_string(generation)
    propagate writer_write_sync(writer, 'Generation {generation_text}\n')

    let mutable y: int64 = 0
    while y < height:
        let mutable x: int64 = 0
        while x < width:
            if is_alive_at(board, width, height, x, y):
                propagate writer_write_sync(writer, '#')
            else:
                propagate writer_write_sync(writer, '.')
            x = x + 1
        propagate writer_write_sync(writer, '\n')
        y = y + 1

    propagate writer_flush_sync(writer)
    return void
