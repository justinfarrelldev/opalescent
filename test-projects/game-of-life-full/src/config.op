##
  Description: Returns the fixed number of columns used by the instructional board.
##
public let board_width = f(): int64 =>
    return 80

##
  Description: Returns the fixed number of rows used by the instructional board.
##
public let board_height = f(): int64 =>
    return 40

##
  Description: Returns the fixed frame rate used by the animated terminal app.
##
public let target_frames_per_second = f(): int32 =>
    return 15

##
  Description: Computes the number of cells in the flat row-major board storage.
##
public let board_cell_count = f(width: int64, height: int64): int64 =>
    return width * height

##
  Description: Returns the numeric value used for living cells in the flat board array.
##
public let alive_cell = f(): int8 =>
    return 1 as int8

##
  Description: Returns the numeric value used for empty cells in the flat board array.
##
public let dead_cell = f(): int8 =>
    return 0 as int8
