import type Point, Rect from ./models.types

##
  Description: Entry point for the import-types-multiple fixture
##
entry main = f(args: string[]): void =>
    let origin: Point = new Point:
        x: 0
        y: 0
    let r: Rect = new Rect:
        top_left: origin
        width: 10
        height: 20
    print('Rect {r.width}x{r.height} at ({r.top_left.x},{r.top_left.y})')
    return void
