# This file should print the final result despite it not being in single quotes or string syntax
##
    Description: Adds two numbers together
##
public let add = f(num1: int32, num2: int32): int32 => 
    return num1 + num2

##
    Description: Reads two integers and prints their final sum result
##
entry main = f(): void errors ParseError => 
    print('Enter num 1:')
    let num1 = take_input()
    print('Enter num 2:')
    let num2 = take_input()

    guard string_to_int32(num1) into num1_int else e => 
        print('An error occurred: {e}')
        propagate e

    guard string_to_int32(num2) into num2_int else e => 
        print('An error occurred: {e}')
        propagate e

    print(add(num1_int, num2_int))

    return void
