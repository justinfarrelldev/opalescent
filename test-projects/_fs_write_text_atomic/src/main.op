import path_from, join_path_components, write_text_sync, move_path_sync, delete_file_sync, read_text_sync, int64_to_string from standard

##
  Description: Demonstrates atomic write via composed workdir, temp file, and move.
##
entry main = f(args: string[]): void errors FileNotFoundError, PermissionDeniedError, IsADirectoryError, InvalidPathError, WriteFailureError, FilesystemFullError, MoveFailureError, FileAlreadyExistsError, DeleteFailureError, ReadFailureError, InvalidUtf8Error =>
    let work_dir_raw = '/tmp'
    let work_dir = path_from(work_dir_raw)
    let target_path = join_path_components(work_dir, ['opalescent-fs-write-text-atomic-strict.txt'])
    let tmp_path = join_path_components(work_dir, ['opalescent-fs-write-text-atomic-strict.txt.tmp.1'])
    let payload = 'atomic payload'

    propagate write_text_sync(tmp_path, payload)

    propagate move_path_sync(tmp_path, target_path)

    let written = propagate read_text_sync(target_path)
    print('wrote atomically: {int64_to_string(written.length)}')
    return void
