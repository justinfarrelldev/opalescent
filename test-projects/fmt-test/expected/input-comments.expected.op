# File header comment

# This file tests comment preservation in the formatter

##
Description: Adds two integers together
##
let add = f(a: int32, b: int32): int32 => {
    # Step 1: Add the values
    let result = a + b
    # Step 2: Return the result
    return result
}

# Section separator - utility functions follow

##
Description: Multiplies two integers
##
let multiply = f(x: int32, y: int32): int32 => {
    # Initialize accumulator
    let mutable acc = 0
    # Loop through and accumulate
    let mutable i = 0
    while i < y {
        acc = acc + x
        i = i + 1
    }
    return acc
}

# Entry point

entry main = f(args: string[]): void => {
    # Call add function
    let sum = add(5, 3)
    # Call multiply function
    let product = multiply(4, 2)
    return void
}
