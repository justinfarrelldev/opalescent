##
  Description: Runs the push red fixture for mutable array growth behavior.
##
entry main = f(args: string[]): void =>
    let mutable xs: int32[] = []
    xs.push(10 as int32)
    xs.push(25 as int32)
    xs.push(8 as int32)
    print('length {xs.length}')
    print('values {xs[0]} {xs[1]} {xs[2]}')
    return void
