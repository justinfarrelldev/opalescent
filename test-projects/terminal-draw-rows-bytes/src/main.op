import stdout_terminal, terminal_draw_rows_sync, flush_standard_output_sync from standard

##
  Description: Verifies terminal_draw_rows_sync joins rows with newlines and no trailing newline.
##
entry main = f(args: string[]): void errors TerminalWriteFailureError, FlushFailureError, SinkClosedError =>
    let terminal = stdout_terminal()
    propagate terminal_draw_rows_sync(terminal, ['##', '..'])
    propagate flush_standard_output_sync()
    return void
