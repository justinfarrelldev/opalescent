##
  Description: Verifies FrameClock constructor rejects negative fps.
##
entry main = f(args: string[]): void errors InvalidFrameRateError =>
    guard new FrameClock:
        frames_per_second: (0 - 1) as int32
    else err =>
        print('fps=-1:{err}')
        propagate err

    print('UNEXPECTED_SUCCESS fps=-1')
    return void
