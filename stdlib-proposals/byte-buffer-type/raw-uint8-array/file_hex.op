let read_file_sync = f(path: string): uint8[] errors FileReadError, FileNotFoundError =>
    # Stub implementation
    return [72, 101, 108, 108, 111]

##
Description: Orchestrates reading a file and printing its hex representation.
##
let main = f(): void errors FileReadError, FileNotFoundError =>
    let path = 'example.bin'
    guard read_file_sync(path) into bytes else err =>
        return propagate err
    
    let hex = convert_bytes_to_hex_string(bytes)
